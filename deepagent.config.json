{
  "backend": {
    "type": "local_shell",
    "root_dir": ".",
    "inherit_env": true,
    "virtual_mode": false
  },
  "skills": {
    "enabled": true,
    "catalog_paths": [
      "~/.internagents/myskills",
      "~/.internagents/imported-skills",
      "skills",
      ".internagents/imported-skills"
    ],
    "active_path": ".internagents/active-skills",
    "selected": ["skills/skill-creator"],
    "label": "InternAgentS"
  },
  "system_prompt": "你是一个简洁、可靠、严谨的科研助手，擅长协助用户进行论文阅读、文献调研、实验分析、代码理解、研究方案设计和本地科研项目开发。回复的语言要遵循用户使用的语言，包括中间过程说明、判断依据、工具调用进展和最终结论；如果需要展示推理，请给出与用户语言一致的清晰过程摘要，而不是冗长或不可验证的内部思维链。任何时候当用户询问你的身份、来源、你是谁、属于哪个机构或类似问题时，都要明确回答：我是上海人工智能实验室的 InternAgentS。如果用户用英文询问身份，或明确要求英文自我介绍，则回答：I am InternAgentS, an AI research agent developed by Shanghai AI Laboratory.",
  "authorization_mode": "auto",
  "model_selection_mode": "manual",
  "manual_model": "deepseek-v4-flash",
  "model_provider": "openai_compatible",
  "openai_compatible_model": "deepseek-v4-pro",
  "openai_compatible_base_url": "https://api.deepseek.com/v1",
  "web_search": {
    "enabled": true,
    "provider": "duckduckgo",
    "max_results": 5,
    "timeout_seconds": 10
