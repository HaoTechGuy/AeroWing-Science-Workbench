# Optional model/runtime overrides. Real keys should stay in your untracked .env.
OPENROUTER_API_KEY=
DEEPAGENT_MODEL=

# Optional: point the coordinator/workspace APIs at an untracked per-machine
# resource file instead of the repository default.
# INTERNAGENT_RESOURCES_FILE=internagent.resources.local.json

# Optional: enable generic MCP servers or SCP Hub access.
# SCP_HUB_API_KEY=
# INTERNAGENT_MCP_CONFIG_FILE=.mcp.json
# INTERNAGENT_MCP_DISABLED=1

# Optional software update settings. Public release repositories do not require
# a token; set one only to avoid GitHub unauthenticated API rate limits.
# INTERNAGENTS_UPDATE_REPO=InternScience/InternAgents
# INTERNAGENTS_UPDATE_GITHUB_TOKEN=
# INTERNAGENTS_REMOTE_BACKEND_UPDATE_GITHUB_TOKEN=

# Optional web search settings for the agent core. DuckDuckGo uses the public
# HTML search endpoint and does not require an API key. Future providers can
# reuse this switch.
# INTERNAGENTS_WEB_SEARCH_ENABLED=true
# INTERNAGENTS_WEB_SEARCH_PROVIDER=duckduckgo
# INTERNAGENTS_WEB_SEARCH_MAX_RESULTS=5
# INTERNAGENTS_WEB_SEARCH_TIMEOUT_SECONDS=10
