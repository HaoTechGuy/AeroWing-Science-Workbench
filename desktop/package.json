{
  "name": "aerowing-science-workbench-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop packaging for AeroWing Science Workbench.",
  "main": "electron/main.cjs",
  "scripts": {
    "prepare:dist": "node scripts/prepare-dist.mjs --desktop",
    "prepare:desktop": "node scripts/prepare-dist.mjs --desktop",
    "prepare:remote": "node scripts/prepare-dist.mjs --remote",
    "sign:adhoc": "node scripts/build-mac.mjs --sign-only",
    "pack": "npm run prepare:dist && node scripts/build-mac.mjs --dir",
    "pack:arm64": "INTERNAGENTS_DESKTOP_ARCH=arm64 npm run pack",
    "pack:x64": "INTERNAGENTS_DESKTOP_ARCH=x64 npm run pack",
    "build": "npm run prepare:dist && node scripts/build-mac.mjs --dmg",
    "build:arm64": "INTERNAGENTS_DESKTOP_ARCH=arm64 npm run build",
    "build:x64": "INTERNAGENTS_DESKTOP_ARCH=x64 npm run build",
    "pack:win": "npm run prepare:dist && node scripts/build-win.mjs --dir",
    "build:win": "npm run prepare:dist && node scripts/build-win.mjs --nsis",
    "build:win:zip": "npm run prepare:dist && node scripts/build-win.mjs --zip",
    "build:win:all": "npm run prepare:dist && node scripts/build-win.mjs --nsis --zip"
  },
  "build": {
    "appId": "com.aerowing.scienceworkbench",
    "productName": "AeroWing Science Workbench",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.developer-tools",
      "identity": null,
      "hardenedRuntime": false,
      "target": [
        "dmg"
      ]
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../dist-app/ui-standalone",
        "to": "ui-standalone",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../dist-app/internagents-template",
        "to": "internagents-template",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../dist-app/python-runtime",
        "to": "python-runtime",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../dist-app/office-tools",
        "to": "office-tools",
        "filter": [
          "**/*"
        ]
      }
    ],
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  }
}
